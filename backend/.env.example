# 后台服务端口
PORT=3001

# JWT 密钥（生产环境务必修改）
JWT_SECRET=home-sxlb-secret-key-change-in-production

# 前端地址
FRONTEND_URL=http://localhost:3000

# 日志级别
LOG_LEVEL=info

# 版本更新检查 URL（可配置为 GitHub API 或私有服务器）
UPDATE_CHECK_URL=https://api.github.com/repos/yourusername/home-sxlb/releases/latest

# 版本更新包下载地址
UPDATE_DOWNLOAD_URL=https://github.com/yourusername/home-sxlb/releases/download

# 管理员默认账号密码（首次安装后请及时修改）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# 数据库路径
DB_PATH=./database/home-sxlb.db
